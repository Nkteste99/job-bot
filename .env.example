# Copy to .env and fill values. Keep this file out of version control.

# --- Supabase (database) ---
# Create your Supabase project and paste the project URL and anon/service key.
SUPABASE_URL=
SUPABASE_KEY=

# --- Telegram (notifications) ---
# Telegram bot token (format: 123456:ABC-DEF...)
TELEGRAM_BOT_TOKEN=
# Telegram chat ID to send notifications to
TELEGRAM_CHAT_ID=

# --- User profile (used for submissions and metadata) ---
USER_NAME=
USER_EMAIL=
USER_LINKEDIN=
USER_GITHUB=
CURRICULO_PDF_PATH=

# --- App settings ---
# Optional: set logging level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# --- Docker / runtime ---
# When running in docker, keep these defaults; override in a local .env when needed.
PYTHONUNBUFFERED=1
