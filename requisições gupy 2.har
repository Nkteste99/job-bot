:\"in_process\",\"reprovedTrigger\":null,\"candidateHasViewedCurriculum\":false,\"job\":{\"expiresAt\":\"2026-07-31\",\"expireDays\":39,\"id\":11522661,\"name\":\"Analytics Engineer\",\"status\":\"published\",\"numVacancies\":1,\"publishedAt\":\"2026-06-22T10:56:22.862Z\",\"jobType\":\"vacancy_type_effective\",\"quickApply\":false,\"careerPage\":{\"hasFriendlyBadge\":true},\"jobSteps\":[{\"endDate\":\"2026-07-31\",\"id\":68210939,\"status\":\"not_started\",\"order\":0,\"type\":\"register\",\"name\":\"Cadastro\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Nesta etapa voc\u00ea precisar\u00e1 preencher todos os campos obrigat\u00f3rios do seu curr\u00edculo e realizar o teste de perfil, caso esteja dispon\u00edvel. Dica: na se\u00e7\u00e3o de experi\u00eancias profissionais, conte suas principais realiza\u00e7\u00f5es e conquistas. Isso ajudar\u00e1 muito em sua avalia\u00e7\u00e3o.\",\"onlineTestType\":null,\"category\":\"registration\",\"daysLeft\":37,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141582,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":16,\"stepId\":68210939,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210937,\"status\":\"not_started\",\"order\":1,\"type\":\"offline\",\"name\":\"Pr\u00e9 Entrevista\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Esta \u00e9 nossa primeira etapa do processo seletivo. O objetivo \u00e9 bater um papo para conhecer melhor seus objetivos profissionais e apresentar os detalhes da vaga :)\",\"onlineTestType\":null,\"category\":\"screening\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141577,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210937,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210936,\"status\":\"not_started\",\"order\":2,\"type\":\"offline\",\"name\":\"Entrevista T\u00e9cnica \",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Queremos conhecer melhor sua hist\u00f3ria profissional. O objetivo desta etapa \u00e9 permitir que nosso time t\u00e9cnico  conhe\u00e7a sua trajet\u00f3ria, assim como entender seus conhecimentos t\u00e9cnicos. \\nO intuito \u00e9 ser uma conversa leve, com bastante trocas de experi\u00eancias entre profissionais.\",\"onlineTestType\":null,\"category\":\"interview\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141581,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210936,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210935,\"status\":\"not_started\",\"order\":3,\"type\":\"offline\",\"name\":\"Em An\u00e1lise\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Este momento \u00e9 dedicado para analisarmos os perfis que se destacaram at\u00e9 aqui :)\",\"onlineTestType\":null,\"category\":\"offer\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141580,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210935,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":fa