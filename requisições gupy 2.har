ession":4505, "text":"{\"id\":728310830,\"currentStepId\":68210939,\"registrationComplete\":true,\"status\":\"in_process\",\"reprovedTrigger\":null,\"candidateHasViewedCurriculum\":false,\"job\":{\"expiresAt\":\"2026-07-31\",\"expireDays\":39,\"id\":11522661,\"name\":\"Analytics Engineer\",\"status\":\"published\",\"numVacancies\":1,\"publishedAt\":\"2026-06-22T10:56:22.862Z\",\"jobType\":\"vacancy_type_effective\",\"quickApply\":false,\"careerPage\":{\"hasFriendlyBadge\":true},\"jobSteps\":[{\"endDate\":\"2026-07-31\",\"id\":68210939,\"status\":\"not_started\",\"order\":0,\"type\":\"register\",\"name\":\"Cadastro\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Nesta etapa voc\u00ea precisar\u00e1 preencher todos os campos obrigat\u00f3rios do seu curr\u00edculo e realizar o teste de perfil, caso esteja dispon\u00edvel. Dica: na se\u00e7\u00e3o de experi\u00eancias profissionais, conte suas principais realiza\u00e7\u00f5es e conquistas. Isso ajudar\u00e1 muito em sua avalia\u00e7\u00e3o.\",\"onlineTestType\":null,\"category\":\"registration\",\"daysLeft\":37,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141582,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"done\",\"testId\":null,\"testProvider\":null,\"skipped\":false,\"applicantsCount\":16,\"stepId\":68210939,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210937,\"status\":\"not_started\",\"order\":1,\"type\":\"offline\",\"name\":\"Pr\u00e9 Entrevista\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Esta \u00e9 nossa primeira etapa do processo seletivo. O objetivo \u00e9 bater um papo para conhecer melhor seus objetivos profissionais e apresentar os detalhes da vaga :)\",\"onlineTestType\":null,\"category\":\"screening\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141577,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210937,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210936,\"status\":\"not_started\",\"order\":2,\"type\":\"offline\",\"name\":\"Entrevista T\u00e9cnica \",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Queremos conhecer melhor sua hist\u00f3ria profissional. O objetivo desta etapa \u00e9 permitir que nosso time t\u00e9cnico  conhe\u00e7a sua trajet\u00f3ria, assim como entender seus conhecimentos t\u00e9cnicos. \\nO intuito \u00e9 ser uma conversa leve, com bastante trocas de experi\u00eancias entre profissionais.\",\"onlineTestType\":null,\"category\":\"interview\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141581,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210936,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210935,\"status\":\"not_started\",\"order\":3,\"type\":\"offline\",\"name\":\"Em An\u00e1lise\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Este momento \u00e9 dedicado para analisarmos os perfis que se destacaram at\u00e9 aqui :)\",\"onlineTestType\":null,\"category\":\"offer\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141580,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210935,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210938,\"status\":\"not_started\",\"order\":4,\"type\":\"offline\",\"name\":\"Entrevista Cultural\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Aqui na ioasys o \u201cDe Pessoas Para Pessoas\u201d \u00e9 uma pr\u00e1tica verdadeira. Queremos conhecer melhor  a pessoa al\u00e9m do profissional que vimos nos \u00faltimos encontros. O objetivo desta etapa \u00e9 conhecer um pouquinho mais sobre seus valores e habilidades interpessoais.\\n\",\"onlineTestType\":null,\"category\":\"interview\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141576,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210938,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":null,\"id\":68210934,\"status\":\"not_started\",\"order\":5,\"type\":\"offline\",\"name\":\"Finalistas\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Este \u00e9 o nosso Banco de Talentos! Se voc\u00ea chegou at\u00e9 aqui significa que voc\u00ea se destacou em toda sele\u00e7\u00e3o e gostamos muito de conhecer voc\u00ea.\",\"onlineTestType\":null,\"category\":\"pre-hiring\",\"daysLeft\":0,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141579,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210934,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false},{\"endDate\":\"2026-07-31\",\"id\":68210933,\"status\":\"not_started\",\"order\":100,\"type\":\"final\",\"name\":\"Contrata\u00e7\u00e3o\",\"testPlatform\":null,\"testId\":null,\"objectivesDescription\":\"Esta \u00e9 a etapa final do processo seletivo, na qual voc\u00ea ser\u00e1 contatado para receber informa\u00e7\u00f5es mais detalhadas sobre a oferta de emprego. Com a proposta aceita, o recrutador te passar\u00e1 orienta\u00e7\u00f5es importantes e documentos necess\u00e1rios.\",\"onlineTestType\":null,\"category\":\"hiring\",\"daysLeft\":37,\"disabled\":null,\"customTest\":null,\"applicationStep\":{\"id\":4062141578,\"linkToTest\":null,\"newCode\":null,\"result\":null,\"score\":null,\"status\":\"not-started\",\"testId\":null,\"testProvider\":null,\"skipped\":null,\"applicantsCount\":0,\"stepId\":68210933,\"customTestReuseInformation\":{\"reusableApplicationStepId\":null,\"hasReusableScore\":false,\"answeredAt\":null,\"latestScore\":null}},\"hasUserViews\":false}],\"applicantCount\":16,\"lastMovementAt\":\"2026-06-23T21:53:10.155Z\",\"isConfidential\":false},\"candidate\":{\"id\":25139658,\"currentProfileId\":10623431},\"useExternalProfileTest\":false,\"isFirstCVCompletedInCompany\":true}", "mimeType":"application/json", "size":6390}, "headersSize":804, "httpVersion":"HTTP/2", "status":200}, "cache":{}, "timings":{"dns":0, "send":13, "wait":152, "connect":0, "blocked":-1, "receive":0}, "startedDateTime":"2026-06-23T19:19:25.8301241-03:00", "_publicFiddlerId":1108}, {"time":141, "request":{"url":"https://private-api.gupy.io/curriculums/25139658/professional-experiences", "bodySize":0, "headers":[{"name":"host", "value":"private-api.gupy.io"}, {"name":"accept", "value":"*/*"}, {"name":"access-control-request-method", "value":"GET"}, {"name":"access-control-request-headers", "value":"content-type"}, {"name":"origin", "value":"https://ioasys.gupy.io"}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML