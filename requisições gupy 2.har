ain", "value":"ioasys"}, {"name":"candidate_secure_token", "value":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MjUxMzk2NTgsImVtYWlsIjoibmljb2dvbGVpcm8yMDAzQGdtYWlsLmNvbSIsImNhbmRpZGF0ZUF1dGhLZXkiOnsidG9rZW4iOiJjZGlkOjI1MTM5NjU4OmJmNTlmOGZkLTlhMmEtNDc4NS04YzJiLTU0NzAwYmY5MGZmNyJ9LCJjb21wYW55Ijp7ImlkIjo3MDJ9LCJpYXQiOjE3ODIyNTI1NTgsImV4cCI6MTc4MzU0ODU1OH0.jftB8rmLukvCSyJbNfMKD3OXBw8VAkf87XFk8Cwtx18"}, {"name":"candidate_logged_in", "value":"true"}, {"name":"_BEAMER_USER_ID_nJNsJSdR35967", "value":"af5a5370-2a00-4af3-815b-c2fe2cd6adbd"}, {"name":"_clck", "value":"1u2yrxz%5E2%5Eg75%5E0%5E2365"}, {"name":"_hjSession_809470", "value":"eyJpZCI6ImQwNDZiYTU0LWI5YWItNDAwMC1iNTlhLWQ4ZDMzNGFiNmZiOSIsImMiOjE3ODIyNTI0NzU1NjQsInMiOjAsInIiOjAsInNiIjowLCJzciI6MCwic2UiOjAsImZzIjoxLCJzcCI6MH0"}, {"name":"_ga_J069CX0DSG", "value":"GS2.1.s1782252480$o1$g0$t1782252585$j60$l0$h0"}, {"name":"gupy_locale", "value":"en"}, {"name":"_ga_XG128X3X29", "value":"GS2.1.s1782252473$o1$g1$t1782252614$j31$l0$h0"}, {"name":"_clsk", "value":"pc5ofy%5E1782252621439%5E5%5E0%5Ek.clarity.ms%2Fcollect"}, {"name":"_ga_0M1NYZV48Q", "value":"GS2.1.s1782252484$o1$g1$t1782253162$j57$l0$h0"}]}, "response":{"redirectURL":"", "statusText":"200", "bodySize":856, "cookies":[], "headers":[{"name":"date", "value":"Tue, 23 Jun 2026 22:19:22 GMT"}, {"name":"content-type", "value":"application/json"}, {"name":"vary", "value":"Accept-Encoding"}, {"name":"access-control-allow-credentials", "value":"true"}, {"name":"access-control-allow-headers", "value":"Authorization,Origin,X-Requested-With,Content-Type,Accept,company_key_auth,candidate_key,admin_key,fulltext,traceparent,x-datadog-trace-id,x-datadog-parent-id,x-datadog-origin,x-datadog-sampling-priority,X-Page-Context,x-page-context,X-Client-Name,x-client-name"}, {"name":"access-control-allow-methods", "value":"GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS"}, {"name":"access-control-allow-origin", "value":"https://ioasys.gupy.io"}, {"name":"content-security-policy", "value":"default-src 'none'"}, {"name":"permissions-policy", "value":"fullscreen=(), geolocation=(), camera()"}, {"name":"referrer-policy", "value":"no-referrer"}, {"name":"timing-allow-origin", "value":"*"}, {"name":"x-content-type-options", "value":"nosniff"}, {"name":"x-frame-options", "value":"DENY"}, {"name":"content-encoding", "value":"gzip"}], "content":{"compression":679, "text":"{\"highlightPresentations\":[{\"id\":119769933,\"type\":\"text\",\"content\":\"Sou um profissional em in\u00edcio de carreira com experi\u00eancia como estagi\u00e1rio na Vivo, onde tive a oportunidade de desenvolver uma base s\u00f3lida em tecnologia e infraestrutura. Durante esse per\u00edodo, participei da cria\u00e7\u00e3o de um ambiente em SharePoint, contribuindo para a organiza\u00e7\u00e3o da informa\u00e7\u00e3o e colabora\u00e7\u00e3o entre equipes.\\nAl\u00e9m da experi\u00eancia profissional, venho desenvolvendo projetos pr\u00f3prios que ampliaram significativamente meus conhecimentos t\u00e9cnicos. Atualmente, estou criando o Job Bot, uma solu\u00e7\u00e3o voltada para automa\u00e7\u00e3o da busca e gest\u00e3o de vagas de emprego, envolvendo integra\u00e7\u00e3o de sistemas, banco de dados, automa\u00e7\u00f5es e notifica\u00e7\u00f5es.\\nTamb\u00e9m desenvolvo um projeto de atendimento inteligente utilizando Intelig\u00eancia Artificial, RAG (Retrieval-Augmented Generation) e n8n, com foco na automa\u00e7\u00e3o de atendimentos, integra\u00e7\u00e3o entre sistemas e fornecimento de respostas contextualizadas com base em bases de conhecimento. Esse projeto tem contribu\u00eddo para o aprimoramento das minhas habilidades em automa\u00e7\u00e3o, IA aplicada e constru\u00e7\u00e3o de fluxos inteligentes.\\nAcredito que posso contribuir com a empresa trazendo uma postura proativa, capacidade de aprendizado cont\u00ednuo e interesse genu\u00edno por tecnologia e inova\u00e7\u00e3o. Tenho facilidade para me adaptar a novos desafios, gosto de trabalhar em equipe e busco constantemente aprimorar minhas habilidades para entregar solu\u00e7\u00f5es eficientes e gerar valor para o neg\u00f3cio.\\n\"}]}", "mimeType":"application/json", "size":1535}, "headersSize":804, "httpVersion":"HTTP/2", "status":200}, "cache":{}, "timings":{"dns":0, "send":9, "wait":158, "connect":0, "blocked":-1, "receive":1}, "startedDateTime":"2026-06-23T19:19:22.4818059-03:00", "_publicFiddlerId":1102}, {"time":140, "request":{"url":"https://private-api.gupy.io/consent-engine/candidate/user-consent", "bodySize":75, "headers":[{"name":"host", "value":"private-api.gupy.io"}, {"name":"content-length", "value":"75"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36"}, {"name":"sec-ch-ua", "value":"\"Google Chrome\";v=\"149\", \"Chromium\";v=\"149\", \"Not)A;Brand\";v=\"24\""}, {"name":"content-type", "value":"application/json"}, {"name":"sec-ch-ua-mobile", "value":"?0"}, {"name":"accept", "value":"*/*"}, {"name":"origin", "value":"https://ioasys.gupy.io"}, {"name":"sec-fetch-site", "value":"same-site"}, {"name":"sec-fetch-mode", "value":"cors"}, {"name":"sec-fetch-dest", "value":"empty"}, {"name":"referer", "value":"https://ioasys.gupy.io/"}, {"name":"accept-encoding", "value":"gzip, deflate, br, zstd"}, {"name":"accept-language", "value":"pt-BR,pt;q=0.9,en-US;q=0.8,en;q=0.7"}, {"name":"priority", "value":"u=1, i"}, {"name":"cookie", "value":"_ga=GA1.1.1823981279.1782252474; gupy_cdcp=sendKey_ACCEPT_ALLALL%26tUserId%3D0mpM2111411117790711467890.025923251208054165.1782252480000%3Atrue; _hjSessionUser_809470=eyJpZCI6ImIyM2E2ZTIyLTNjZTItNTVmNS05NmQ1LTZlMTc1NGI2NzU3NSIsImNyZWF0ZWQiOjE3ODIyNTI0NzU1NjIsImV4aXN0aW5nIjp0cnVlfQ==; _fbp=fb.1.1782252476179.458698231881111346; last_candidate_auth_subdomain=ioasys; candidate_secure_token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MjUxMzk2NTgsImVtYWlsIjoibmljb2dvbGVpcm8yMDAzQGdtYWlsLmNvbSIsImNhbmRp